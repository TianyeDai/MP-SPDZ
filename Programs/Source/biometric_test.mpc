# biometric_test.mpc
#
# Squared-Euclidean-distance biometric matching that mirrors the C frontend
# (tests/biometric/inputs/biometric.c in the user's other SPDZ pipeline).
#
# Structure -- a literal nested loop, just like the C code:
#
#   for (i = 0; i < N; ++i) {                                  outer (threaded)
#       sum = 0;
#       for (j = 0; j < D; ++j) {                              inner
#           diff = S[i*D + j] - C[j];
#           sum += diff * diff;
#       }
#       sums[i] = sum;
#   }
#   // then a sequential argmin pass over sums[0..N-1] -> (min_sum, min_idx)
#   return min_idx + min_sum;
#
# Inputs:
#   Party 0  ->  Player-Data/Input-P0-0  : probe vector C  (D values)
#   Party 1  ->  Player-Data/Input-P1-0  : database S      (N * D values, row-major)
#
# Compile-time config (env vars):
#   N        -- template count *and* dimension; the workload is square (N == D)
#   THREADS  -- number of compute threads for the OUTER per-template loop

from Compiler.types import sint, Array, cint, MultiArray, MemValue
from Compiler.library import for_range_multithread, for_range_opt, print_ln
from Compiler import util
import os


def _get_int(name, default):
    try:
        return int(os.environ.get(name, default))
    except Exception:
        return default


# Square workload: N (templates) == D (dim) == _N
_N = _get_int("N", 2048)
THREADS = max(1, _get_int("THREADS", 1))

N_TPL = _N
D_DIM = _N

# ---------------------------------------------------------------------------
# Inputs
# ---------------------------------------------------------------------------
C = sint.Array(D_DIM)
C.input_from(0)

S = sint.Matrix(N_TPL, D_DIM)
S.input_from(1)

# ---------------------------------------------------------------------------
# Nested loop: outer over templates (threaded), inner over dimensions.
#
# The inner loop accumulates into a memory-backed sint register (`acc`)
# because Python-closure variables don't carry across runtime loop
# iterations -- each `@for_range_opt` iteration is a separate runtime
# block, not a re-execution of the Python body. `MemValue` (or
# equivalently a 1-element sint Array) gives us a load/store-able cell.
#
# `@for_range_opt` is the inner loop: it runs at runtime (single bytecode
# block, executed D times) and may auto-batch iterations for vectorization.
# Use `@for_range(D_DIM)` instead if you want strictly scalar, no auto-vec.
# ---------------------------------------------------------------------------
sums = sint.Array(N_TPL)


@for_range_multithread(THREADS, 1, N_TPL)
def _(i):
    acc = MemValue(sint(0))           # uint32_t sum = 0;

    @for_range_opt(D_DIM)
    def _(j):
        diff = S[i][j] - C[j]         # int32_t diff = S[i*D+j] - C[j];
        acc.write(acc.read() + diff * diff)   # sum += diff * diff;

    sums[i] = acc.read()              # store this template's sum


# ---------------------------------------------------------------------------
# Sequential argmin scan -- mirrors C's `if (sum < min_sum) { ... }` chain.
# Done as a Python-unrolled fold: a single left-to-right pass that, at each
# step, replaces the running (min_sum, min_idx) with the current candidate
# whenever `sums[i] < running_min`. This produces the same circuit shape as
# the C scan (N-1 secret comparisons in series).
#
# (If you'd rather have logarithmic round depth, swap this for a
#  util.tree_reduce -- same semantics, different round structure.)
# ---------------------------------------------------------------------------
min_sum = sums[0]
min_idx = sint(0)
for i in range(1, N_TPL):
    less = sums[i] < min_sum                     # secret 0/1
    min_sum = less.if_else(sums[i], min_sum)
    min_idx = less.if_else(sint(i), min_idx)

# ---------------------------------------------------------------------------
# Output: mirror the C frontend's `return min_idx + min_sum;`.
# Stored in a cint Array so DCE doesn't drop the reveal.
# ---------------------------------------------------------------------------
result = min_sum + min_idx
y_open = Array(1, cint)
y_open[0] = result.reveal()
print_ln('biometric result (min_idx + min_sum) = %s', y_open[0])
