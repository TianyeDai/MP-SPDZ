# biometric_test.mpc
#
# Squared-Euclidean-distance biometric matching that mirrors the C frontend
# (tests/biometric/inputs/biometric.c in the user's other SPDZ pipeline).
#
# For each template i in the database S (N rows of D values), compute:
#       dist[i] = sum_{j=0..D-1} (S[i][j] - C[j])^2
# then return:
#       min_idx + min_sum                       (matches the C return value)
#
# Inputs:
#   Party 0  ->  Player-Data/Input-P0-0  : probe vector C  (D values)
#   Party 1  ->  Player-Data/Input-P1-0  : database S      (N * D values, row-major)
#
# Compile-time config (env vars):
#   N        -- template count *and* dimension; the workload is square (N == D)
#   THREADS  -- number of compute threads for the per-template inner loop
#
# This file is the MP-SPDZ counterpart of biometric.c + biometric_new.sh in
# the user's parallel pipeline.

from Compiler.types import sint, Array, cint, MultiArray
from Compiler.library import for_range_multithread, print_ln
from Compiler import util
import os


def _get_int(name, default):
    try:
        return int(os.environ.get(name, default))
    except Exception:
        return default


# Square workload: N (templates) == D (dim) == _N
_N = _get_int("N", 2048)
THREADS = max(1, _get_int("THREADS", 1))

N_TPL = _N
D_DIM = _N

# ---------------------------------------------------------------------------
# Inputs
# ---------------------------------------------------------------------------
C = sint.Array(D_DIM)
C.input_from(0)

S = sint.Matrix(N_TPL, D_DIM)
S.input_from(1)

# ---------------------------------------------------------------------------
# Per-template squared distances (parallel across templates)
#
#   diff = S[i][:] - C[:]
#   sums[i] = <diff, diff>
#
# get_part_vector(i, 1) returns the i-th row of S as a vectorized sint of
# length D, which lets us do the whole inner loop as a single vectorized
# subtract + dot_product instead of unrolling D scalar ops at compile time.
# ---------------------------------------------------------------------------
sums = sint.Array(N_TPL)


@for_range_multithread(THREADS, 1, N_TPL)
def _(i):
    diff = S.get_part_vector(i, 1) - C.get_vector()
    sums[i] = sint.dot_product(diff, diff)


# ---------------------------------------------------------------------------
# Argmin via tree reduction over (sum, idx) pairs.
# At each step we pick the pair with the smaller sum, dragging its index
# along with it -- exactly mirroring the `if (sum < min_sum)` branch in C.
# ---------------------------------------------------------------------------
def reduce_min(a, b):
    a_sum, a_idx = a
    b_sum, b_idx = b
    less = a_sum < b_sum                          # secret 0/1
    return (less.if_else(a_sum, b_sum),
            less.if_else(a_idx, b_idx))


pairs = [(sums[i], sint(i)) for i in range(N_TPL)]
min_sum, min_idx = util.tree_reduce(reduce_min, pairs)

# ---------------------------------------------------------------------------
# Output: mirror the C frontend's `return min_idx + min_sum;`.
# Stored in a cint Array so DCE doesn't drop the reveal.
# ---------------------------------------------------------------------------
result = min_sum + min_idx
y_open = Array(1, cint)
y_open[0] = result.reveal()
print_ln('biometric result (min_idx + min_sum) = %s', y_open[0])
